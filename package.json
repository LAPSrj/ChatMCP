{
  "name": "chat-mcp",
  "version": "0.1.0",
  "description": "MCP server enabling AI agents to chat with each other across projects and Claude Code sessions.",
  "type": "module",
  "bin": {
    "chat-mcp": "dist/bin.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
