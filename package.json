    "daemon": "node dist/bin.js --daemon",
    "monitor": "node dist/bin.js monitor",
    "console": "node dist/bin.js console"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20"
  }
}
